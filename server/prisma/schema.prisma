generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TxType {
  earned
  spent
}

enum ActivityType {
  walking
  running
  cycling
  swimming
  yoga
  gym
}

enum RewardCategory {
  food
  wellness
  sport
  eco
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String
  partner          String         @default("intel")
  stepGoal         Int            @default(8000)
  balance          Int            @default(450)
  declarationsToday Int           @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  activities       Activity[]
  declarations     Declaration[]
  transactions     Transaction[]
  notifications    Notification[]
  achievements     Achievement[]
}

model Reward {
  id          String         @id @default(cuid())
  icon        String
  title       String
  merchant    String
  category    RewardCategory
  cost        Int
  code        String         @unique
  description String
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  minutes   Int
  steps     Int
  points    Int
  createdAt DateTime     @default(now())
}

model Declaration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  points    Int
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  points    Int
  type      TxType
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key         String
  title       String
  unlockedAt  DateTime @default(now())
}
