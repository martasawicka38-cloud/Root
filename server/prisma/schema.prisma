generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TxType {
  earned
  spent
}

enum ActivityType {
  walking
  running
  cycling
  swimming
  yoga
  gym
}

enum EcoCategory {
  MOBILITY
  CIRCULARITY
  LOCAL_CONSUMPTION
  NATURE_ACTIVITY
}

enum RewardCategory {
  food
  wellness
  sport
  eco
}

enum UserRole {
  user
  employer
  company
  superadmin
}

enum TokenType {
  company_registration
  employer_registration
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  passwordHash      String
  role              UserRole @default(user)
  isActive          Boolean  @default(true)
  partner           String   @default("intel")
  stepGoal          Int      @default(8000)
  balance           Int      @default(450)
  declarationsToday Int      @default(0)
  totalExp          Int      @default(0)
  canTransform      Boolean  @default(false)
  rootStageId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyId   String?
  company     Company?      @relation("UserCompany", fields: [companyId], references: [id])
  usedTokenId String?       @unique
  usedToken   CompanyToken? @relation("TokenUsage", fields: [usedTokenId], references: [id])

  activities              Activity[]
  declarations            Declaration[]
  transactions            Transaction[]
  notifications           Notification[]
  achievements            Achievement[]
  challengeParticipations ChallengeParticipation[]
  challenges              Challenge[]
  ecoActivityLogs         UserEcoActivityLog[]
  rootStage               RootStage?                    @relation(fields: [rootStageId], references: [id])
}

model Company {
  id               String                   @id @default(cuid())
  name             String                   @unique
  slug             String                   @unique
  createdAt        DateTime                 @default(now())
  users            User[]                   @relation("UserCompany")
  tokens           CompanyToken[]
  challenges       Challenge[]
  ecoActivities    EcoActivity[]
  globalPermission CompanyGlobalPermission?
}

model CompanyToken {
  id        String    @id @default(cuid())
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      TokenType @default(employer_registration)
  token     String    @unique
  used      Boolean   @default(false)
  usedAt    DateTime?
  usedBy    User?     @relation("TokenUsage")
  createdAt DateTime  @default(now())
}

model Reward {
  id          String         @id @default(cuid())
  icon        String
  title       String
  merchant    String
  category    RewardCategory
  cost        Int
  code        String         @unique
  description String
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  minutes   Int
  steps     Int
  points    Int
  createdAt DateTime     @default(now())
}

model Declaration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  points    Int
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  points    Int
  type      TxType
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key        String
  title      String
  unlockedAt DateTime @default(now())
}

model Challenge {
  id              String                   @id @default(cuid())
  title           String
  description     String?
  points          Int
  scope           String                   @default("company")
  companyId       String?
  company         Company?                 @relation(fields: [companyId], references: [id])
  createdByUserId String?
  createdByUser   User?                    @relation(fields: [createdByUserId], references: [id])
  grantedById     String?
  active          Boolean                  @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  participations  ChallengeParticipation[]
}

model ChallengeParticipation {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([challengeId, userId])
}

model CompanyGlobalPermission {
  id          String    @id @default(cuid())
  companyId   String    @unique
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  grantedById String
  used        Boolean   @default(false)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model RootStage {
  id          String  @id @default(cuid())
  name        String
  level       Int     @unique
  expRequired Int
  description String?

  users User[]
}

model EcoActivity {
  id              String       @id @default(cuid())
  name            String       @unique
  description     String?
  icon            String       @default("leaf")
  category        EcoCategory
  basePoints      Int          @default(10)
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  // Reward activity fields
  activityType    String       @default("permanent") // one_time | cyclical | permanent
  expiresAt       DateTime?    // for cyclical activities
  companyId       String?      // null = global, specific = company-only
  createdByUserId String?      // who created it

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  logs UserEcoActivityLog[]
}

model UserEcoActivityLog {
  id             String      @id @default(cuid())
  userId         String
  ecoActivityId  String
  basePoints     Int
  multiplier     Float       @default(1.0)
  leaderboardPts Int         @default(0)
  expPoints      Int         @default(0)
  createdAt      DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ecoActivity EcoActivity @relation(fields: [ecoActivityId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ecoActivityId, userId, createdAt])
}
